# ==============================
# Distill — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/distill

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers
DEEPSEEK_API_KEY=your_deepseek_api_key
QWEN_API_KEY=your_qwen_api_key
DOUBAO_API_KEY=your_doubao_api_key   # used as LLM judge
ANTHROPIC_API_KEY=your_anthropic_api_key  # optional, pluggable judge

# ASR
SENSEVOICE_ENDPOINT=http://localhost:8000  # self-hosted SenseVoice

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
