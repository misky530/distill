# 复制为 .env，填入实际值，docker compose 会自动读取
# 注意：.env 不要提交到git，已在.gitignore中排除
# 火山方舟 (Volcano Ark) coding plan
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DEEPSEEK_MODEL=deepseek-v4-pro
KIMI_MODEL=kimi-k2.6
DOUBAO_MODEL=doubao-seed-2.0-pro
# 硅基流动 ASR
SILICONFLOW_API_KEY=
# 视频下载（路径因机器而异，Windows本地开发需要填，容器内通常已在标准PATH）
YT_DLP_PATH=
FFMPEG_PATH=
FFPROBE_PATH=
BILIBILI_COOKIES_PATH=
